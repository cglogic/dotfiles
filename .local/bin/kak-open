#!/bin/sh

if [ ! -p "$1" ]; then
	exit 0
fi

if [ ! -n "${TMUX+x}" ]; then
	sleep 0.05
fi

# FILE=$(fzf)
FILE=$(ag --nocolor -l -g "" | sort | fzy -l max -p "❯❯❯ ")
# FILE=$(ag --nocolor -l -g "" | sort | waitwinch fzy -l max -p "❯❯❯ " 2> /dev/null)

if [ ! -n "$FILE" ] || [ ! -f "$FILE" ]; then
	exit 0
fi

echo "edit $FILE" > $1
